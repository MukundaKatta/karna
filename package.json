{
  "name": "karna",
  "version": "0.1.0",
  "private": true,
  "description": "Karna — Your Loyal AI Agent Platform",
  "author": "Officethree Technologies",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "gateway:dev": "pnpm --filter @karna/gateway dev",
    "gateway:start": "pnpm --filter @karna/gateway start",
    "cli": "pnpm --filter @karna/cli start"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}

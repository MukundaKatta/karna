{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/dashboard/sessions/[id]",
      "regex": "^/dashboard/sessions/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/dashboard/sessions/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/chat",
      "regex": "^/chat(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/chat(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/dashboard/agents",
      "regex": "^/dashboard/agents(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/agents(?:/)?$"
    },
    {
      "page": "/dashboard/analytics",
      "regex": "^/dashboard/analytics(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/analytics(?:/)?$"
    },
    {
      "page": "/dashboard/memory",
      "regex": "^/dashboard/memory(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/memory(?:/)?$"
    },
    {
      "page": "/dashboard/sessions",
      "regex": "^/dashboard/sessions(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/sessions(?:/)?$"
    },
    {
      "page": "/dashboard/settings",
      "regex": "^/dashboard/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/settings(?:/)?$"
    },
    {
      "page": "/dashboard/skills",
      "regex": "^/dashboard/skills(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/skills(?:/)?$"
    },
    {
      "page": "/dashboard/tools",
      "regex": "^/dashboard/tools(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/tools(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}
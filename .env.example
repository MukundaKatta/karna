# ============================================================
# Karna — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required fields are marked [REQUIRED]. Everything else is optional.
# ============================================================

# ─── AI Providers ───────────────────────────────────────────
# At least one LLM provider is required.

# [REQUIRED] Anthropic API key — primary LLM provider
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — used for embeddings, Whisper STT, and fallback LLM
OPENAI_API_KEY=sk-...

# OpenAI-compatible base URL — useful for Gemini or OpenRouter
OPENAI_BASE_URL=

# Optional default runtime override — useful for hosted deploys
KARNA_DEFAULT_PROVIDER=
KARNA_DEFAULT_MODEL=

# ─── Gateway ────────────────────────────────────────────────

# Port the gateway WebSocket server listens on
GATEWAY_PORT=18789

# [REQUIRED in production] Shared secret for channel → gateway auth
# Generate with: openssl rand -hex 32
GATEWAY_AUTH_TOKEN=

# CORS origins (comma-separated). Use * only in development.
# Supports both local Docker and hosted frontends like Vercel.
GATEWAY_CORS_ORIGINS=http://localhost:3000,http://localhost:3100

# ─── Hosted Web Dashboard ──────────────────────────────────
# Needed when deploying apps/web separately from the gateway.

# Server-side proxy target used by Next.js API routes
GATEWAY_URL=http://localhost:4000

# Public browser endpoint for direct REST calls and derived WebSocket URL
NEXT_PUBLIC_GATEWAY_URL=http://localhost:4000

# Optional explicit WebSocket URL for the browser.
# If omitted, the web app derives it from NEXT_PUBLIC_GATEWAY_URL.
NEXT_PUBLIC_WS_URL=

# Optional invite gate for hosted beta deployments.
# When KARNA_BETA_ACCESS_CODE is set, public users must enter it at /sign-in
# before reaching chat, dashboards, or protected API routes.
KARNA_BETA_ACCESS_CODE=

# Optional dedicated signing secret for beta session cookies.
# If omitted, the access code itself is used to sign the cookie.
KARNA_WEB_SESSION_SECRET=

# ─── Database (Supabase / PostgreSQL) ───────────────────────
# Required for persistent sessions, memory, and cloud features.
# Not needed for local-only / in-memory mode.

SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection (used by migrations)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/karna

# ─── Cloud API (apps/cloud) ────────────────────────────────
# Only needed if running the multi-tenant cloud API.

# [REQUIRED for cloud] JWT signing secret — minimum 32 characters
# Generate with: openssl rand -base64 48
JWT_SECRET=

# Cloud API port
CLOUD_API_PORT=3100

# ─── Channel Adapters ──────────────────────────────────────
# Configure only the channels you want to use.

# Telegram — https://core.telegram.org/bots#botfather
TELEGRAM_BOT_TOKEN=

# Discord — https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# Slack — https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# WhatsApp (via Baileys — scans QR code on first run)
# No token needed — uses QR code authentication

# SMS (Twilio) — https://twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...
SMS_WEBHOOK_PORT=3400

# Signal (via signal-cli REST API)
SIGNAL_API_URL=http://localhost:8080
SIGNAL_PHONE_NUMBER=+1...

# Google Chat — https://console.cloud.google.com
GOOGLE_CHAT_SERVICE_ACCOUNT_PATH=
GOOGLE_CHAT_WEBHOOK_PORT=3401

# Microsoft Teams — https://dev.teams.microsoft.com
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
TEAMS_TENANT_ID=
TEAMS_BOT_PORT=3402

# Matrix — https://matrix.org
MATRIX_HOMESERVER_URL=https://matrix.org
MATRIX_ACCESS_TOKEN=
MATRIX_USER_ID=@karna:matrix.org

# IRC
IRC_SERVER=irc.libera.chat
IRC_PORT=6697
IRC_NICK=karna-bot
IRC_CHANNELS=#karna
IRC_USE_TLS=true

# LINE — https://developers.line.biz
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_WEBHOOK_PORT=3403

# ─── Voice ──────────────────────────────────────────────────

# ElevenLabs TTS — https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── Payments ───────────────────────────────────────────────
# Only needed if running the cloud API with billing.

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay — https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=

# ─── Observability ──────────────────────────────────────────

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Langfuse (LLM observability) — enable with: docker compose --profile monitoring up
LANGFUSE_SECRET=
LANGFUSE_SALT=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3200

# ─── Docker Compose Defaults ────────────────────────────────

POSTGRES_PASSWORD=postgres
